{
  "name": "@brendankemp/eslint-plugin-css-modules",
  "version": "3.0.0",
  "description": "Checks that you are using the existent css/scss/less classes, no more no less",
  "main": "./build/cjs/index.js",
  "module": "./build/esm/index.js",
  "types": "./build/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/esm/index.d.ts",
      "import": "./build/esm/index.js",
      "require": "./build/cjs/index.js",
      "default": "./build/cjs/index.js"
    }
  },
  "files": [
    "build",
    "packages"
  ],
  "scripts": {
    "build": "rm -rf build && tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json",
    "test": "mocha 'test/**/*.test.ts' --require tsx",
    "my-pre-publish": "npm run test && npm run build",
    "my-publish": "npm run my-pre-publish && npm publish --access public"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "css-modules"
  ],
  "author": {
    "name": "Brendan Kemp",
    "email": "brendan.kemp@gmail.com",
    "url": "https://brendankemp.com"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/brendankemp/eslint-plugin-css-modules.git"
  },
  "license": "MIT",
  "peerDependencies": {
    "eslint": ">=2.0.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/eslint": "^9.6.1",
    "@types/lodash": "^4.17.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "chai": "^4.3.9",
    "eslint": "^8.50.0",
    "mocha": "^10.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "gonzales-pe": "^4.3.0",
    "lodash": "^4.17.2"
  }
}
